# 이 파일을 복사해서 .env 로 만들고 실제 값을 채워넣으세요
# cp .env.example .env

# 외부에서 접근하는 API 주소 (브라우저/앱이 호출하는 주소)
# 서버 배포 시: http://<서버IP>:3001
API_URL=http://localhost:3001

# PostgreSQL 연결 문자열 (docker-compose 내부 통신용, 변경 불필요)
DATABASE_URL=postgresql://mymemory:mymemory@postgres:5432/mymemory

# CLI 사용 시 (선택 - mem.sh에서 MEM_API_URL 환경변수로 덮어쓰기 가능)
# export MEM_API_URL=http://<서버IP>:3001
