generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Card {
  id           String   @id @default(cuid())
  title        String
  body         String
  tag          String   // linux | docker | k8s | general
  source       String?
  easeFactor   Float    @default(2.5)
  interval     Int      @default(1)
  repetitions  Int      @default(0)
  nextReviewAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reviews      Review[]
  relationsFrom CardRelation[] @relation("FromCard")
  relationsTo   CardRelation[] @relation("ToCard")
}

model CardRelation {
  id         String   @id @default(cuid())
  fromCardId String
  toCardId   String
  type       String   // 'related' | 'deepdive'
  depth      Int      @default(0) // deepdive 순서 (0=related)
  createdAt  DateTime @default(now())

  fromCard   Card     @relation("FromCard", fields: [fromCardId], references: [id], onDelete: Cascade)
  toCard     Card     @relation("ToCard", fields: [toCardId], references: [id], onDelete: Cascade)

  @@unique([fromCardId, toCardId])
}

model Review {
  id        String   @id @default(cuid())
  cardId    String
  rating    Int      // 0=again, 3=hard, 5=good
  createdAt DateTime @default(now())

  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
}
